<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dk.easv.ticketseasv.gui.TicketController">

    <content>
        <VBox spacing="32">
            <padding>
                <Insets bottom="10" left="32" right="32" top="32" />
            </padding>

            <!-- ================= TOP BAR ================= -->
            <HBox alignment="CENTER_LEFT" spacing="0">
                <!-- Logo Left -->
                <ImageView fitHeight="100" preserveRatio="true" smooth="true">
                    <image>
                        <Image url="@images/skolelogoigen.png" />
                    </image>
                </ImageView>

                <!-- Spacer -->
                <Region HBox.hgrow="ALWAYS" />

                <!-- Profile Right -->
                <HBox alignment="CENTER" spacing="7">
                    <ImageView fitHeight="40" fitWidth="40" preserveRatio="true" smooth="true">
                        <image>
                            <Image url="@images/userIcon.png" />
                        </image>
                    </ImageView>
                    <Label style="-fx-font-size: 16px; -fx-font-weight: 500;" text="Event coordinator" />
                </HBox>
            </HBox>

            <!-- ================= HEADER ================= -->
            <VBox alignment="CENTER" spacing="12">
                <Label style="-fx-font-size: 40px; -fx-font-weight: 500;" text="The Voice" />

                <Label style="-fx-font-size: 20px; -fx-text-fill: #717182;" text="Karaoke night at SEA’s friday bar!" />
            </VBox>

            <!-- ================= MAIN CONTENT ================= -->
            <HBox spacing="32">

                <!-- ========== LEFT SIDE (Event Info) ========== -->
                <VBox prefWidth="560" spacing="24">

                    <!-- Event Card -->
                    <VBox spacing="24" style="-fx-background-color: white;                                  -fx-background-radius: 14;                                  -fx-padding: 24;                                  -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 20, 0.2, 0, 8);">

                        <!-- Image -->
                        <StackPane>
                            <ImageView fitHeight="260" fitWidth="559" preserveRatio="true">
                                <image>
                                    <Image url="@images/TheVoiceTitleCard.png" />
                                </image>
                            </ImageView>
                            <Label style="-fx-background-color: #9810fa;                                           -fx-text-fill: white;                                           -fx-padding: 4 8 4 8;                                           -fx-background-radius: 4;" text="Friday bar" StackPane.alignment="BOTTOM_LEFT" />
                        </StackPane>

                        <!-- Event Details -->
                        <VBox spacing="16">
                            <Label style="-fx-font-size: 20px; -fx-font-weight: 500;" text="Event Details" />

                            <VBox spacing="12">
                                <Label style="-fx-font-size: 16px;" text="Friday, February 30, 2026" />
                                <Label style="-fx-font-size: 14px; -fx-text-fill: #717182;" text="Make sure to reserve the date in your calendar ;D" />

                                <Label style="-fx-font-size: 16px;" text="7:30 PM - 1:00 AM" />
                                <Label style="-fx-font-size: 14px; -fx-text-fill: #717182;" text="Karaoke starts @ 8 PM" />

                                <Label style="-fx-font-size: 16px;" text="SEA’s basement bar" />
                                <Label style="-fx-font-size: 14px; -fx-text-fill: #717182;" text="I’m sure you already know where it is" />
                            </VBox>
                        </VBox>

                        <!-- About -->
                        <VBox spacing="8">
                            <Separator />
                            <Label style="-fx-font-size: 16px; -fx-font-weight: 500;" text="About This Event" />

                            <Label style="-fx-font-size: 14px; -fx-text-fill: #717182;" text="Channel your inner Whitney Houston for this year’s karaoke night! If you just Wanna Dance With Somebody, we have a dance floor for that :D" wrapText="true" />
                        </VBox>
                    </VBox>

                    <!-- Ticket Price Card -->
                    <VBox spacing="8" style="-fx-background-color: white;                                  -fx-background-radius: 14;                                  -fx-padding: 24;                                  -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 20, 0.2, 0, 8);">

                        <Label style="-fx-font-size: 14px; -fx-text-fill: #717182;" text="Ticket Price" />

                        <HBox alignment="BASELINE_LEFT" spacing="4">
                            <Label style="-fx-font-size: 48px; -fx-font-weight: bold;" text="125" />
                            <Label style="-fx-font-size: 14px;" text="dkk" />
                        </HBox>
                    </VBox>

                </VBox>

                <!-- ========== RIGHT SIDE (Purchase Form) ========== -->
                <VBox prefWidth="560" spacing="24" style="-fx-background-color: white;                              -fx-background-radius: 14;                              -fx-padding: 24;">

                    <!-- Form Header -->
                    <VBox spacing="8">
                        <Label style="-fx-font-size: 24px; -fx-font-weight: 500;" text="Purchase Tickets" />

                        <Label style="-fx-font-size: 16px; -fx-text-fill: #717182;" text="Fill in the student’s details to complete the purchase" />
                    </VBox>

                    <!-- Customer Information -->
                    <VBox spacing="16">

                        <Label style="-fx-font-size: 18px; -fx-font-weight: 500;" text="Customer Information" />

                        <!-- Full Name -->
                        <VBox spacing="8">
                            <Label style="-fx-font-size: 14px; -fx-font-weight: 500;" text="Full Name *" />
                            <TextField prefHeight="44" promptText="Whitney Houston" style="-fx-background-color: #f3f3f5;                                               -fx-background-radius: 8;" />
                        </VBox>

                        <!-- Email -->
                        <VBox spacing="8">
                            <Label style="-fx-font-size: 14px; -fx-font-weight: 500;" text="Email Address *" />
                            <TextField prefHeight="44" promptText="email@example.com" style="-fx-background-color: #f3f3f5;                                               -fx-background-radius: 8;" />
                        </VBox>

                        <!-- Number of Tickets -->
                        <VBox spacing="8">
                            <Label style="-fx-font-size: 14px; -fx-font-weight: 500;" text="Number of Tickets" />
                            <HBox alignment="CENTER_LEFT" spacing="16">
                                <Button prefHeight="44" prefWidth="44" text="-" />
                                <Label style="-fx-font-size: 16px; -fx-font-weight: 500;" text="1" />
                                <Button prefHeight="44" prefWidth="44" text="+" />
                               <Label style="-fx-font-size: 16px; -fx-text-fill: #717182;" text="× 125 dkk each" />
                            </HBox>
                        </VBox>

                        <!-- Price Per Ticket Info -->
                        <HBox alignment="CENTER_LEFT" spacing="12" />

                        <!-- ================= DELIVERY METHOD ================= -->
                        <VBox spacing="12">

                            <Label style="-fx-font-size: 14px; -fx-font-weight: 500;" text="Delivery Method" />

                            <!-- Email Delivery Option -->
                            <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 16;                  -fx-border-color: rgba(0,0,0,0.1);                  -fx-border-radius: 10;                  -fx-background-radius: 10;">

                                <RadioButton selected="true">
                           <toggleGroup>
                              <ToggleGroup fx:id="deliveryGroup" />
                           </toggleGroup></RadioButton>

                                <VBox spacing="4">
                                    <Label style="-fx-font-size: 14px; -fx-font-weight: 500;" text="Email Delivery" />

                                    <Label style="-fx-font-size: 14px; -fx-text-fill: #717182;" text="Receive tickets instantly via email" />
                                </VBox>
                            </HBox>

                            <!-- Printed Tickets Option -->
                            <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 16;                  -fx-border-color: rgba(0,0,0,0.1);                  -fx-border-radius: 10;                  -fx-background-radius: 10;">

                                <RadioButton toggleGroup="$deliveryGroup" />

                                <VBox spacing="4">
                                    <Label style="-fx-font-size: 14px; -fx-font-weight: 500;" text="Printed Tickets" />

                                    <Label style="-fx-font-size: 14px; -fx-text-fill: #717182;" text="Printed and hand-delivered as fast as the printer can manage it" wrapText="true" />
                                </VBox>
                            </HBox>

                            <fx:define>
                                <ToggleGroup fx:id="deliveryGroup" />
                            </fx:define>

                        </VBox>

                        <!-- ================= ORDER SUMMARY ================= -->
                        <VBox spacing="16" style="-fx-background-color: #faf5ff;              -fx-background-radius: 10;              -fx-padding: 20;">

                            <!-- Tickets Row -->
                            <HBox alignment="CENTER_LEFT">
                                <Label style="-fx-font-size: 16px;" text="Tickets (1)" HBox.hgrow="ALWAYS" />

                                <HBox alignment="BASELINE_RIGHT" spacing="4">
                                    <Label style="-fx-font-size: 24px; -fx-font-weight: 600;" text="125" />
                                    <Label style="-fx-font-size: 14px;" text="dkk" />
                                </HBox>
                            </HBox>

                            <Separator />

                            <!-- Total Row -->
                            <HBox alignment="CENTER_LEFT">
                                <Label style="-fx-font-size: 18px;" text="Total" HBox.hgrow="ALWAYS" />

                                <HBox alignment="BASELINE_RIGHT" spacing="4">
                                    <Label style="-fx-font-size: 24px; -fx-font-weight: 600;" text="125" />
                                    <Label style="-fx-font-size: 14px;" text="dkk" />
                                </HBox>
                            </HBox>

                        </VBox>

                        <!-- ================= SUBMIT BUTTON ================= -->
                        <Button maxWidth="Infinity" prefHeight="40" style="-fx-background-color: #030213;                -fx-text-fill: white;                -fx-font-weight: 500;                -fx-background-radius: 8;" text="Got everything?" />

                    </VBox>

                </VBox>

            </HBox>

        </VBox>
    </content>
</ScrollPane>
