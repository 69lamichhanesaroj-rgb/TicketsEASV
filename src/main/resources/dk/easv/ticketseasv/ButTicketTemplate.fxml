<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true"
            xmlns="http://javafx.com/javafx/24.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dk.easv.ticketseasv.gui.TicketController">

    <content>
        <VBox spacing="32">

            <padding>
                <Insets top="32" right="32" bottom="32" left="32"/>
            </padding>

            <!-- ================= TOP BAR ================= -->
            <HBox alignment="CENTER_LEFT">

                <ImageView fitHeight="100" preserveRatio="true" smooth="true">
                    <image>
                        <Image url="@images/skolelogoigen.png"/>
                    </image>
                </ImageView>

                <Region HBox.hgrow="ALWAYS"/>

                <HBox alignment="CENTER" spacing="7">
                    <ImageView fitHeight="40" fitWidth="40" preserveRatio="true" smooth="true">
                        <image>
                            <Image url="@images/userIcon.png"/>
                        </image>
                    </ImageView>

                    <Label fx:id="roleLbl"
                           text="Event coordinator"
                           style="-fx-font-size: 16px; -fx-font-weight: 500;"/>
                </HBox>

            </HBox>

            <!-- ================= HEADER ================= -->
            <VBox alignment="CENTER" spacing="12">

                <Label fx:id="eventNameLbl"
                       style="-fx-font-size: 40px; -fx-font-weight: 500;"/>

                <Label fx:id="eventDescriptionLbl"
                       style="-fx-font-size: 20px; -fx-text-fill: #717182;"
                       wrapText="true"/>

            </VBox>

            <!-- ================= MAIN CONTENT ================= -->
            <HBox spacing="32">

                <!-- LEFT SIDE -->
                <VBox prefWidth="560" spacing="24">

                    <!-- EVENT CARD -->
                    <VBox spacing="24"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 14;
                                 -fx-padding: 24;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 20, 0.2, 0, 8);">

                        <!-- IMAGE -->
                        <StackPane prefHeight="225.0" prefWidth="512.0">
                            <ImageView fx:id="eventImageView"
                                       fitHeight="250.0"
                                       fitWidth="462.0"
                                       preserveRatio="true"/>
                        </StackPane>

                        <!-- EVENT DETAILS -->
                        <VBox spacing="16">

                            <Label style="-fx-font-size: 20px; -fx-font-weight: 500;"
                                   text="Event Details"/>

                            <VBox spacing="12">

                                <Label text="Date" style="-fx-font-size: 16px;"/>
                                <Label fx:id="eventDateLbl"
                                       style="-fx-font-size: 14px; -fx-text-fill: #717182;"/>

                                <Label text="Location" style="-fx-font-size: 16px;"/>
                                <Label fx:id="eventLocationLbl"
                                       style="-fx-font-size: 14px; -fx-text-fill: #717182;"/>

                            </VBox>
                        </VBox>

                        <!-- ABOUT -->
                        <VBox spacing="8">
                            <Separator/>

                            <Label text="About This Event"
                                   style="-fx-font-size: 16px; -fx-font-weight: 500;"/>

                            <Label fx:id="eventAboutLbl"
                                   wrapText="true"
                                   style="-fx-font-size: 14px; -fx-text-fill: #717182;"/>
                        </VBox>

                    </VBox>

                    <!-- PRICE CARD -->
                    <VBox spacing="8"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 14;
                                 -fx-padding: 24;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 20, 0.2, 0, 8);">

                        <Label text="Ticket Price"
                               style="-fx-font-size: 14px; -fx-text-fill: #717182;"/>

                        <HBox alignment="BASELINE_LEFT" spacing="4">

                            <Label fx:id="ticketPriceLbl"
                                   style="-fx-font-size: 48px; -fx-font-weight: bold;"/>

                            <Label text="dkk"
                                   style="-fx-font-size: 14px;"/>
                        </HBox>

                    </VBox>

                </VBox>

                <!-- RIGHT SIDE -->
                <VBox prefWidth="560"
                      spacing="24"
                      style="-fx-background-color: white;
                             -fx-background-radius: 14;
                             -fx-padding: 24;">

                    <!-- HEADER -->
                    <VBox spacing="8">

                        <Label text="Purchase Tickets"
                               style="-fx-font-size: 24px; -fx-font-weight: 500;"/>

                        <Label text="Fill in details to complete purchase"
                               style="-fx-font-size: 16px; -fx-text-fill: #717182;"/>

                    </VBox>

                    <!-- FORM -->
                    <VBox spacing="16">

                        <Label text="Customer Information"
                               style="-fx-font-size: 18px; -fx-font-weight: 500;"/>

                        <VBox spacing="8">
                            <Label text="Full Name *"/>
                            <TextField fx:id="nameField"
                                       prefHeight="44"
                                       promptText="John Doe"
                                       style="-fx-background-color: #f3f3f5; -fx-background-radius: 8;"/>
                        </VBox>

                        <VBox spacing="8">
                            <Label text="Email *"/>
                            <TextField fx:id="emailField"
                                       prefHeight="44"
                                       promptText="email@example.com"
                                       style="-fx-background-color: #f3f3f5; -fx-background-radius: 8;"/>
                        </VBox>

                        <!-- TICKET COUNT -->
                        <VBox spacing="8">
                            <Label text="Number of Tickets"/>

                            <HBox alignment="CENTER_LEFT" spacing="12">

                                <Button text="-" fx:id="minusBtn"
                                        prefWidth="44" prefHeight="44"/>
                                <Label fx:id="ticketCountLbl"/>
                                <Button text="+" fx:id="plusBtn"
                                        prefWidth="44" prefHeight="44"/>

                            </HBox>
                        </VBox>

                        <!-- DELIVERY -->
                        <VBox spacing="12">

                            <Label text="Delivery Method"/>

                            <fx:define>
                                <ToggleGroup fx:id="deliveryGroup"/>
                            </fx:define>

                            <HBox spacing="12"
                                  style="-fx-padding: 16;
                                         -fx-border-color: rgba(0,0,0,0.1);
                                         -fx-border-radius: 10;
                                         -fx-background-radius: 10;">

                                <RadioButton text="Email Delivery"
                                             toggleGroup="$deliveryGroup"
                                             selected="true"/>

                            </HBox>

                            <HBox spacing="12"
                                  style="-fx-padding: 16;
                                         -fx-border-color: rgba(0,0,0,0.1);
                                         -fx-border-radius: 10;
                                         -fx-background-radius: 10;">

                                <RadioButton text="Printed Tickets"
                                             toggleGroup="$deliveryGroup"/>

                            </HBox>

                        </VBox>

                        <!-- SUMMARY -->
                        <VBox spacing="16"
                              style="-fx-background-color: #faf5ff;
                                     -fx-background-radius: 10;
                                     -fx-padding: 20;">

                            <HBox>
                                <Label text="Tickets " HBox.hgrow="ALWAYS"/>
                                <Label fx:id="subtotalLbl" text="0 dkk"/>
                            </HBox>

                            <Separator/>

                            <HBox>
                                <Label text="Total" HBox.hgrow="ALWAYS"/>
                                <Label fx:id="totalLbl"
                                       style="-fx-font-size: 18px; -fx-font-weight: 600;"
                                       text="0 dkk"/>
                            </HBox>

                        </VBox>

                        <Button text="Buy Ticket"
                                maxWidth="Infinity"
                                prefHeight="44"
                                style="-fx-background-color: #030213;
                                       -fx-text-fill: white;
                                       -fx-background-radius: 8;"/>

                    </VBox>

                </VBox>

            </HBox>

        </VBox>
    </content>
</ScrollPane>
