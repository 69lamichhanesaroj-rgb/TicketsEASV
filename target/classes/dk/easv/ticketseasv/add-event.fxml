<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="dk.easv.ticketseasv.gui.AddEventController"
      spacing="12">

    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>

    <Label fx:id="titleLabel" text="Add New Event" style="-fx-font-size: 18; -fx-font-weight: bold;"/>

    <GridPane hgap="10" vgap="10">
        <Label text="Event Name:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="nameField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="More Info:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="moreInfoField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Start Time (HH:mm):" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="startTimeField" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="End Time (HH:mm):" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextField fx:id="endTimeField" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="Location:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <TextField fx:id="locationField" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

        <Label text="Description:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
        <TextField fx:id="descriptionField" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

        <Label text="When (Date):" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
        <TextField fx:id="whenField" GridPane.rowIndex="6" GridPane.columnIndex="1"/>

        <Label text="Image Path:" GridPane.rowIndex="7" GridPane.columnIndex="0"/>
        <TextField fx:id="imagePathField" GridPane.rowIndex="7" GridPane.columnIndex="1"/>
    </GridPane>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancel" onAction="#onCancel"/>
        <Button fx:id="submitButton" text="Add Event" onAction="#onAddEvent"/>
    </HBox>
</VBox>